# Kopieren nach .env und anpassen ( .env nicht committen — Root-.gitignore )
#
# Docker Compose lädt diese Datei automatisch für Variablen in compose.yaml.

# --- PostgreSQL (Service postgres + Default für DATABASE_URL) ---
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_DB=agent

# Option A: volle URL (Compose übergibt sie an den Agent).
# Option B: Zeile auskommentieren/löschen — dann nutzt der Agent POSTGRES_* unten + PGHOST=postgres aus compose.yaml.
# Bei Sonderzeichen im Passwort: URL-encoden.
DATABASE_URL=postgresql://agent:agent@postgres:5432/agent

# --- Ollama ---
OLLAMA_BASE_URL=http://ollama:11434

# --- Agent HTTP (Host-Port) ---
AGENT_HTTP_PORT=8088

# --- Agent ---
AGENT_MAX_TOOL_ROUNDS=8
# Multi-User: Komma-getrennte Header-Namen, erster nicht-leerer gewinnt (Default im Code:
# X-OpenWebUI-User-Id, X-Agent-User-Sub). Open WebUI: examples/open-webui/docker/compose.yaml
# setzt ENABLE_FORWARD_USER_INFO_HEADERS=true — nichts nötig, außer du willst nur einen Header:
# AGENT_USER_SUB_HEADER=X-OpenWebUI-User-Id
# AGENT_TENANT_ID_HEADER=X-Agent-Tenant-Id
# AGENT_DEFAULT_EXTERNAL_SUB=default
# Pro-User-Geheimnisse verschlüsseln (Fernet, nur Betreiber): python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Niemals ins Git. Endnutzer: Tool register_secrets (OTP+curl). Siehe TOOLS.md → User secrets.
# AGENT_SECRETS_MASTER_KEY=
# Optional: öffentliche Agent-URL für curl-Vorlagen (register_secrets / secrets_help)
# AGENT_PUBLIC_URL=https://agent.example.com
# AGENT_API_KEY=
# AGENT_SYSTEM_PROMPT=You only use registered tools for todos and time; do not invent shell commands.
# AGENT_CONTENT_TOOL_FALLBACK=true
# AGENT_CORS_ORIGINS=*

# --- Plugins (nur Verzeichnis-Scan, keine feste Tool-Liste im Code) ---
# Optional: nur diese Ordner (Komma), sonst Standard = app/plugins im Image + AGENT_PLUGINS_EXTRA_DIR
# AGENT_PLUGIN_DIRS=/app/app/plugins,/data/plugins
# AGENT_PLUGINS_EXTRA_DIR=/data/plugins
# AGENT_PLUGINS_ALLOWED_SHA256=
# Große String-Args in tool_invocations ausblenden (Komma), Default: source
# AGENT_TOOL_LOG_REDACT_KEYS=source
# create_tool: AGENT_CREATE_TOOL_ENABLED=true genügt für Pfad /data/plugins (Default im Code, wenn EXTRA_DIR leer).
# Im compose trotzdem Host-Ordner mounten, z. B. ./extra_plugins:/data/plugins:rw (Docker mountet nicht „von selbst“).
# Nur nötig, wenn du einen anderen Pfad willst: AGENT_PLUGINS_EXTRA_DIR=/irgendwo
# Codegen braucht Ollama + gepulltes Modell (Default qwen2.5-coder:3b). AGENT_PLUGINS_ALLOWED_SHA256 leer fürs Testen.
# create_tool (Chat): schreibt neue *.py in AGENT_PLUGINS_EXTRA_DIR — nur mit vertrauenswürdigem Netz / AGENT_API_KEY.
# AGENT_CREATE_TOOL_ENABLED=false
# AGENT_CREATE_TOOL_MAX_BYTES=120000
# Ohne ``source``: Ollama schreibt Modul aus tool_name (siehe create_tool). Modell + Timeout:
# Default im Code: qwen2.5-coder:3b. Überschreiben z. B. für 7b:
# AGENT_CREATE_TOOL_CODEGEN_MODEL=qwen2.5-coder:7b
# AGENT_CREATE_TOOL_CODEGEN_TIMEOUT=120

# --- Web-Suche (Plugin web_search: search_web, deep_search) ---
# Ohne Keys: Fallback ddgs-Metasuche (inoffiziell, kann ausfallen). Abschalten:
# AGENT_DISABLE_DDG_SEARCH=true
# TAVILY_API_KEY=
# BRAVE_SEARCH_API_KEY=
# AGENT_SEARCH_TIMEOUT=45
# AGENT_SEARCH_MAX_RAW_CHARS=12000
# deep_search ohne Tavily: Snippets + Seitenabruf wenn robots.txt erlaubt
# AGENT_DISABLE_FETCH_DEEP=false
# AGENT_ROBOTS_STRICT=false
# AGENT_FETCH_USER_AGENT=JetpackAgentLayer/1.0 (private)
# AGENT_FETCH_MAX_BYTES=2000000
# AGENT_ROBOTS_CACHE_TTL=3600
# Nur diese Hosts fetchen (Komma, Suffix-Match: docs.godotengine.org erlaubt mit godotengine.org)
# AGENT_FETCH_DOMAIN_ALLOWLIST=godotengine.org,example.com
# X-Robots-Tag / meta robots noindex respektieren (Default an)
# AGENT_RESPECT_META_ROBOTS=true

# --- Lokaler Workspace (Plugin workspace_*: Dateien auf gemounteter Platte) ---
# Trennung zu GitHub: github_get_file holt Inhalte über die GitHub-API; workspace_* arbeitet nur unter
# AGENT_WORKSPACE_ROOT im Container (typisch Host-Ordner per Volume nach /workspace).
# AGENT_WORKSPACE_ROOT=/workspace
# Optional: Limits (Defaults siehe app/config.py)
# AGENT_WORKSPACE_MAX_FILE_BYTES=1200000
# AGENT_WORKSPACE_MAX_LIST_ENTRIES=500
# AGENT_WORKSPACE_MAX_GLOB_FILES=2000
# AGENT_WORKSPACE_MAX_READ_LINES=8000
# AGENT_WORKSPACE_MAX_SEARCH_FILES=2000
# AGENT_WORKSPACE_MAX_SEARCH_MATCHES=100
# AGENT_WORKSPACE_SEARCH_MAX_FILE_BYTES=400000
# Compose-Beispiel (auskommentiert in compose.yaml): - /pfad/auf/host:/workspace:rw

# --- Sonstige Tool-APIs ---
# GitHub (Plugin github_*): read-only REST. Fine-grained PAT empfohlen. Alternativ pro Nutzer Secret `github_pat`.
# GITHUB_TOKEN=
# SERPAPI_API_KEY=
