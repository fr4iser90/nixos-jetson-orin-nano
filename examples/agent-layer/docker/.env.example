# Kopieren nach .env und anpassen ( .env nicht committen — Root-.gitignore )
#
# Docker Compose lädt diese Datei automatisch für Variablen in compose.yaml.

# --- PostgreSQL (Service postgres + Default für DATABASE_URL) ---
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_DB=agent

# Option A: volle URL (Compose übergibt sie an den Agent).
# Option B: Zeile auskommentieren/löschen — dann nutzt der Agent POSTGRES_* unten + PGHOST=postgres aus compose.yaml.
# Bei Sonderzeichen im Passwort: URL-encoden.
DATABASE_URL=postgresql://agent:agent@postgres:5432/agent

# --- Ollama ---
OLLAMA_BASE_URL=http://ollama:11434

# --- Agent HTTP (Host-Port) ---
AGENT_HTTP_PORT=8088

# --- Agent ---
# Max. Tool-Schleifen pro Chat-Request (create_tool → list → read → update …). Default 8; lokal/Jetson oft 12–20.
AGENT_MAX_TOOL_ROUNDS=8
# Max. verschachtelte Tool-Aufrufe (Plugin ruft per invoke_registered_tool ein anderes Tool, das wieder …). Default 24.
# AGENT_TOOL_CHAIN_MAX_DEPTH=24
# Vor replace_tool / update_tool / create_tool (Overwrite): Kopie der alten .py (UTC-Präfix im Dateinamen)
# AGENT_TOOLS_BACKUP_ENABLED=true
# Nur ./extra_tools:/data/tools gemountet? Dann Backup auf dem gleichen Volume (sonst geht’s beim Recreate verloren):
# AGENT_TOOLS_BACKUP_DIR=/data/tools/.tool_backups
# Sonst Default: AGENT_DATA_DIR/tool_backups (= /data/tool_backups im Container)
# AGENT_TOOLS_BACKUP_DIR=/data/tool_backups
# Multi-User: Komma-getrennte Header-Namen, erster nicht-leerer gewinnt (Default im Code:
# X-OpenWebUI-User-Id, X-Agent-User-Sub). Open WebUI: examples/open-webui/docker/compose.yaml
# setzt ENABLE_FORWARD_USER_INFO_HEADERS=true — nichts nötig, außer du willst nur einen Header:
# AGENT_USER_SUB_HEADER=X-OpenWebUI-User-Id
# AGENT_TENANT_ID_HEADER=X-Agent-Tenant-Id
# AGENT_DEFAULT_EXTERNAL_SUB=default
# Pro-User-Geheimnisse verschlüsseln (Fernet, nur Betreiber): python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Niemals ins Git. Endnutzer: Tool register_secrets (OTP+curl). Siehe TOOLS.md → User secrets.
# AGENT_SECRETS_MASTER_KEY=
# Optional: öffentliche Agent-URL für curl-Vorlagen (register_secrets / secrets_help)
# AGENT_PUBLIC_URL=https://agent.example.com
# AGENT_API_KEY=
# AGENT_SYSTEM_PROMPT=You only use registered tools for todos and time; do not invent shell commands.
# AGENT_CONTENT_TOOL_FALLBACK=true
# Pro Ollama-Runde: INFO mit reply=TOOLS vs TEXT_NO_TOOLS, ctx_msgs, grobe ctx_text_chars (Summe sichtbarer Texte),
# content_json_fallback (JSON im Content statt native tool_calls). Bei sehr großem Kontext: LARGE_CTX-Hinweis.
# AGENT_LOG_LLM_ROUNDS=true
# Optional: erste N Zeichen der Assistant-Antwort (redigiert appid=/Bearer); 0=aus
# AGENT_LOG_ASSISTANT_PREVIEW_CHARS=0
# Schwellwert für LARGE_CTX im Log (Zeichen, nur Metrik)
# AGENT_LOG_LARGE_CONTEXT_CHARS=120000
# AGENT_CORS_ORIGINS=*

# --- Tool-Routing (weniger Tools pro Request = weniger Verwechslungen) ---
# Modus: full | tool_factory | workspace | default_chat (Alias: default)
# full = alle Tools (Default). tool_factory = nur create_tool, list_tools, read_tool, update_tool, replace_tool, rename_tool (+ Hilfe).
# workspace = nur workspace_*. default_chat = alles außer Factory + workspace_*.
# AGENT_TOOL_MODE=full
# Header überschreibt JSON: X-Agent-Mode: tool_factory (oder X-Agent-Tool-Mode)
# JSON-Body alternativ: "agent_tool_mode": "tool_factory" (Alias: agent_mode)
# tool_factory inkl. list_available_tools / get_tool_help (Default an):
# AGENT_TOOL_MODE_TOOL_FACTORY_INCLUDES_HELP=true
# Modus-basierte Tool-Teilmenge (tool_factory nur Factory-Tools, workspace nur workspace_*, …): true einschalten
# AGENT_TOOL_SUBSET_BY_MODE=false
# Keyword-Router (letzte User-Message), wenn weder Header noch Body-Modus gesetzt:
# AGENT_TOOL_ROUTER_KEYWORDS_ENABLED=true
# Eigene Trigger (Komma, Teilstrings, case-insensitive); leer = eingebaute Defaults
# AGENT_TOOL_ROUTER_KEYWORDS_TOOL_FACTORY=
# AGENT_TOOL_ROUTER_KEYWORDS_WORKSPACE=
# Optional: zweite Stufe per Ollama (ein kurzer Klassifikations-Call)
# AGENT_TOOL_ROUTER_LLM_ENABLED=false
# AGENT_TOOL_ROUTER_MODEL=qwen2.5-coder:3b
# Nach workspace_*-Fehler („disabled“): restliche Tool-Runden auf tool_factory einschränken
# AGENT_TOOL_RETRY_NARROW_TO_TOOL_FACTORY=true
# Nach Tool-Antworten die wie HTTP-Fehler aussehen (400/401/…, httpx): kurzer System-Hinweis
# (read_tool → search_web → replace_tool). Abschalten: false
# AGENT_TOOL_HTTP_ERROR_RECOVERY_HINTS=true
#
# Kleine Chat-Modelle (Namen-Substring): im Modus tool_factory bestimmte Tools weglassen.
# Default: nemotron/nano → kein update_tool (exakte old_string-Patches scheitern oft; replace_tool nutzen).
# Abschalten: AGENT_WEAK_TOOL_MODEL_SUBSTRINGS=  (leer) oder Exclude leer
# AGENT_WEAK_TOOL_MODEL_SUBSTRINGS=nemotron,nano
# AGENT_WEAK_TOOL_MODEL_EXCLUDE_TOOLS=update_tool
#
# Dedizierter HTTP-Endpunkt (erzwingt tool_factory, optional tool_prefetch im JSON):
# POST /v1/chat/completions/tool-factory

# --- Tools (nur Verzeichnis-Scan, keine feste Tool-Liste im Code) ---
# Optional: nur diese Ordner (Komma), sonst Standard = agent_tools im Image + AGENT_TOOLS_EXTRA_DIR
# AGENT_TOOL_DIRS=/app/agent_tools,/data/tools
# AGENT_TOOLS_EXTRA_DIR=/data/tools
# AGENT_TOOLS_ALLOWED_SHA256=
# Große String-Args in tool_invocations ausblenden (Komma), Default: source
# AGENT_TOOL_LOG_REDACT_KEYS=source
# create_tool: AGENT_CREATE_TOOL_ENABLED=true genügt für Pfad /data/tools (Default im Code, wenn EXTRA_DIR leer).
# Im compose trotzdem Host-Ordner mounten, z. B. ./extra_tools:/data/tools:rw (Docker mountet nicht „von selbst“).
# Nur nötig, wenn du einen anderen Pfad willst: AGENT_TOOLS_EXTRA_DIR=/irgendwo
# Codegen braucht Ollama + gepulltes Modell (Default im Code: qwen2.5-coder:7b — unabhängig vom Chat-Modell in der UI).
# create_tool (Chat): schreibt neue *.py in AGENT_TOOLS_EXTRA_DIR — nur mit vertrauenswürdigem Netz / AGENT_API_KEY.
# AGENT_CREATE_TOOL_ENABLED=false
# AGENT_CREATE_TOOL_MAX_BYTES=120000
# Ohne ``source``: Ollama schreibt Modul aus tool_name (siehe create_tool). Modell + Timeout:
# AGENT_CREATE_TOOL_CODEGEN_MODEL=qwen2.5-coder:7b
# AGENT_CREATE_TOOL_CODEGEN_TIMEOUT=120
# Codegen darf HTTP (OpenWeather etc.): Keys nur als Env im Container, im Tool os.environ.get("…")
# AGENT_CREATE_TOOL_CODEGEN_ALLOW_NETWORK=false
# Codegen auto-retry: Ollama-Versuche bei Validierungs- oder test_tool-Fehler (Default 1 = aus; z. B. 4)
# AGENT_CREATE_TOOL_CODEGEN_MAX_ATTEMPTS=1
# OpenWeather: eingebautes Tool ``openweather_current`` (agent_tools/openweather) + dynamische Tools
# OPENWEATHER_API_KEY=

# --- Web-Suche (Tool web_search: search_web, deep_search) ---
# Ohne Keys: Fallback ddgs-Metasuche (inoffiziell, kann ausfallen). Abschalten:
# AGENT_DISABLE_DDG_SEARCH=true
# TAVILY_API_KEY=
# BRAVE_SEARCH_API_KEY=
# AGENT_SEARCH_TIMEOUT=45
# AGENT_SEARCH_MAX_RAW_CHARS=12000
# deep_search ohne Tavily: Snippets + Seitenabruf wenn robots.txt erlaubt
# AGENT_DISABLE_FETCH_DEEP=false
# AGENT_ROBOTS_STRICT=false
# AGENT_FETCH_USER_AGENT=JetpackAgentLayer/1.0 (private)
# AGENT_FETCH_MAX_BYTES=2000000
# AGENT_ROBOTS_CACHE_TTL=3600
# Nur diese Hosts fetchen (Komma, Suffix-Match: docs.godotengine.org erlaubt mit godotengine.org)
# AGENT_FETCH_DOMAIN_ALLOWLIST=godotengine.org,example.com
# X-Robots-Tag / meta robots noindex respektieren (Default an)
# AGENT_RESPECT_META_ROBOTS=true

# --- Lokaler Workspace (Tool workspace_*: Dateien auf gemounteter Platte) ---
# Trennung zu GitHub: github_get_file holt Inhalte über die GitHub-API; workspace_* arbeitet nur unter
# AGENT_WORKSPACE_ROOT im Container (typisch Host-Ordner per Volume nach /workspace).
# AGENT_WORKSPACE_ROOT=/workspace
# Optional: Limits (Defaults siehe app/config.py)
# AGENT_WORKSPACE_MAX_FILE_BYTES=1200000
# AGENT_WORKSPACE_MAX_LIST_ENTRIES=500
# AGENT_WORKSPACE_MAX_GLOB_FILES=2000
# AGENT_WORKSPACE_MAX_READ_LINES=8000
# AGENT_WORKSPACE_MAX_SEARCH_FILES=2000
# AGENT_WORKSPACE_MAX_SEARCH_MATCHES=100
# AGENT_WORKSPACE_SEARCH_MAX_FILE_BYTES=400000
# Compose-Beispiel (auskommentiert in compose.yaml): - /pfad/auf/host:/workspace:rw

# --- Sonstige Tool-APIs ---
# GitHub (Tool github_*): read-only REST. Fine-grained PAT empfohlen. Alternativ pro Nutzer Secret `github_pat`.
# GITHUB_TOKEN=
# SERPAPI_API_KEY=
